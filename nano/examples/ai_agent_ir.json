{
  "type": "Strategy",
  "nanoIrVersion": "0.1.0",
  "name": "AiAgent",
  "effects": ["intent.emit", "log.append"],
  "nodes": [
    { "type": "Schedule", "interval": "1m" },
    { "type": "Condition", "signal": "OPPORTUNITY", "operator": ">=", "value": 90 },
    { "type": "Intent", "action": "OBSERVE" },
    { "type": "Intent", "action": "EXECUTE" },
    { "type": "Agent", "name": "ATS" }
  ]
}
